# Copy this file to ".env.local" and fill in real values.
# ".env.local" is gitignored — never commit secrets.

# Oura personal access token (Sleep tab → server proxy)
OURA_TOKEN=

# FatSecret Platform OAuth (Calories tab → /api/fatsecret/proxy)
# https://platform.fatsecret.com/my-account/credentials
# Use Client ID and Client Secret (two different strings).
# IP whitelist (FatSecret dashboard, not here): 0.0.0.0/0 = allow any IPv4 source.
# If the UI has a separate IPv6 field, ::/0 = allow any IPv6 (only if FatSecret documents it).
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# Supabase (bundled into the client build — use publishable/anon key only)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Anthropic (Coach tab serverless — never expose in client)
ANTHROPIC_API_KEY=
